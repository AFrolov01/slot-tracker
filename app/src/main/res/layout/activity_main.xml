<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎰 Slot Tracker"
            android:textColor="@color/gold"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <!-- Setup Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Настройки"
                android:textColor="@color/gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:textColorHint="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStartBalance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Начальный баланс"
                        android:inputType="number"
                        android:text="140000"
                        android:textColor="@color/text_main" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColorHint="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBetSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ставка"
                        android:inputType="number"
                        android:text="500"
                        android:textColor="@color/text_main" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сохранить настройки"
                android:layout_marginTop="8dp"
                app:backgroundTint="@color/gold"
                android:textColor="@color/bg_dark" />
        </LinearLayout>

        <!-- Service Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Статус сервиса"
                android:textColor="@color/gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvServiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❌ Сервис не активен — открой настройки Accessibility и включи Slot Tracker"
                android:textColor="@color/negative"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenAccessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Открыть настройки Accessibility"
                app:backgroundTint="@color/warning"
                android:textColor="@color/bg_dark" />
        </LinearLayout>

        <!-- Live Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Статистика сессии"
                android:textColor="@color/gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true">

                <TextView
                    android:id="@+id/tvTotalSpins"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="Спинов: 0"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#0f0f1a" />

                <TextView
                    android:id="@+id/tvNetProfit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="Прибыль: 0"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#0f0f1a" />

                <TextView
                    android:id="@+id/tvRoi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="ROI: 0%"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#0f0f1a" />

                <TextView
                    android:id="@+id/tvStrikeRate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="Strike Rate: 0%"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#0f0f1a" />

                <TextView
                    android:id="@+id/tvAvgMult"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="Средний x: 0.00"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#0f0f1a" />

                <TextView
                    android:id="@+id/tvMaxDD"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="Max DD: 0%"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#0f0f1a" />
            </GridLayout>

            <TextView
                android:id="@+id/tvCurrentBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Текущий баланс: —"
                android:textColor="@color/gold"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Recommendation -->
        <TextView
            android:id="@+id/tvRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Запусти сервис и начни играть — статистика появится автоматически."
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:background="@color/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Last Spins -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📜 Последние спины"
                android:textColor="@color/gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvSpinHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Нет данных"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ Сбросить статистику"
            android:layout_marginTop="12dp"
            app:backgroundTint="#7f8c8d"
            android:textColor="#fff" />

    </LinearLayout>
</ScrollView>
